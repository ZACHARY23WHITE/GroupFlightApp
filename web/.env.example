DATABASE_URL="file:./dev.db"

# If you use the “Network” URL (e.g. http://192.168.1.5:3000) instead of localhost, add your LAN IP here
# so Next.js dev mode can load client scripts. Comma-separated. Restart `npm run dev` after changing.
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.5

# Google Flights–style search via SerpAPI (paid tier; free trial credits).
# Sign up: https://serpapi.com/ — engine docs: https://serpapi.com/google-flights-api
SERPAPI_API_KEY=

# Optional localization for Google Flights results
# SERPAPI_GL="us"
# SERPAPI_HL="en"

# Slower but closer to the google.com/travel/flights UI (optional)
# SERPAPI_DEEP_SEARCH="true"

# Set to "true" to force demo prices even if SERPAPI_API_KEY is set
# SERPAPI_DISABLED="false"

# Milliseconds to wait for SerpAPI (default 120000)
# SERPAPI_TIMEOUT_MS=120000
